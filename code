# ROBOT
# ══════════════════════════════════════════════
DIRECTIONS = [(-1,0),(0,1),(1,0),(0,-1)]   # Up Right Down Left

class Robot:
    def __init__(self, start, goal, grid, fuzzy_params=None):
        self.row, self.col = start
        self.goal_row, self.goal_col = goal
        self.grid    = grid
        self.facing  = 1
        self.path    = [start]
        self.steps   = 0
        self.collisions = 0
        self.fuzzy   = FuzzyNavigator(fuzzy_params)
        self.reached = False
        self.visited = {}
        self.stuck_count = 0
        self.max_steps = 500

    def dist_to_goal(self):
        return math.sqrt((self.row-self.goal_row)**2+(self.col-self.goal_col)**2)

    def angle_to_goal(self):
        dr = self.goal_row - self.row
        dc = self.goal_col - self.col
        diff = math.degrees(math.atan2(dc, dr)) - self.facing*90
        while diff >  180: diff -= 360
        while diff < -180: diff += 360
        return diff

    def sense_distance(self, direction_idx):
        dr,dc = DIRECTIONS[direction_idx]
        r,c,dist = self.row,self.col,0
        while dist < 10:
            r+=dr; c+=dc; dist+=1
            if not (0<=r<len(self.grid) and 0<=c<len(self.grid[0])): return dist
            if self.grid[r][c]==1: return dist
        return dist

    def _neighbour_visits(self, direction_idx):
        dr,dc = DIRECTIONS[direction_idx]
        return self.visited.get((self.row+dr, self.col+dc), 0)

    def step(self):
        if self.reached: return

        dist_f = self.sense_distance(self.facing)
        dist_l = self.sense_distance((self.facing-1)%4)
        dist_r = self.sense_distance((self.facing+1)%4)
        vf = self._neighbour_visits(self.facing)
        vl = self._neighbour_visits((self.facing-1)%4)
        vr = self._neighbour_visits((self.facing+1)%4)

        action, _ = self.fuzzy.infer(
            self.dist_to_goal(), self.angle_to_goal(),
            dist_f, dist_l, dist_r,
            visit_front=vf, visit_left=vl, visit_right=vr
        )

        if action == 0:
            nr=self.row+DIRECTIONS[self.facing][0]; nc=self.col+DIRECTIONS[self.facing][1]
            if self._valid(nr,nc): self.row,self.col=nr,nc
            else: self.collisions+=1; self.facing=(self.facing+1)%4
        elif action == 1:
            self.facing=(self.facing-1)%4
            nr=self.row+DIRECTIONS[self.facing][0]; nc=self.col+DIRECTIONS[self.facing][1]
            if self._valid(nr,nc): self.row,self.col=nr,nc
        elif action == 2:
            self.facing=(self.facing+1)%4
            nr=self.row+DIRECTIONS[self.facing][0]; nc=self.col+DIRECTIONS[self.facing][1]
            if self._valid(nr,nc): self.row,self.col=nr,nc
        elif action == 3:
            self.facing=(self.facing+2)%4

        self.steps+=1
        pos=(self.row,self.col)
        self.visited[pos]=self.visited.get(pos,0)+1
        self.stuck_count=self.visited[pos]
        # Escape heuristic: if visiting same cell too often, force a better move
        if self.stuck_count > 6:
            self.escape_step()
            pos=(self.row,self.col)
            self.visited[pos]=self.visited.get(pos,0)+1
            self.stuck_count=self.visited[pos]
        if not self.path or self.path[-1]!=pos: self.path.append(pos)
        if pos==(self.goal_row,self.goal_col): self.reached=True


    def escape_step(self):
        """When truly stuck, pick least-visited free neighbour toward goal."""
        best_pos, best_score = None, float('inf')
        for d in range(4):
            dr,dc = DIRECTIONS[d]
            nr,nc = self.row+dr, self.col+dc
            if self._valid(nr,nc):
                v = self.visited.get((nr,nc), 0)
                # score: visits + distance to goal (prefer less-visited + closer)
                dist = math.sqrt((nr-self.goal_row)**2+(nc-self.goal_col)**2)
                score = v*3 + dist
                if score < best_score:
                    best_score, best_pos = score, (nr,nc,d)
        if best_pos:
            nr,nc,d = best_pos
            self.row,self.col = nr,nc
            self.facing = d

    def _valid(self,r,c):
        return 0<=r<len(self.grid) and 0<=c<len(self.grid[0]) and self.grid[r][c]==0

# ══════════════════════════════════════════════
# GENETIC ALGORITHM
# ══════════════════════════════════════════════
GENE_BOUNDS = [
    (1.0, 3.0),(1.5, 4.5),(2.5, 6.0),
    (10.0,60.0),(0.1,0.9),(0.5,2.0),
    (0.1,1.0),(0.0,1.0),
]
POP_SIZE  = 20
N_GEN     = 15
MAX_STEPS = 400

def random_chromosome():
    return [random.uniform(lo,hi) for lo,hi in GENE_BOUNDS]

def evaluate(chrom, grid, start, goal):
    robot = Robot(start, goal, grid, fuzzy_params=chrom)
    for _ in range(MAX_STEPS):
        if robot.reached or robot.stuck_count>30: break
        robot.step()
    dist = robot.dist_to_goal()
    maxd = math.sqrt(len(grid)**2+len(grid[0])**2)
    if robot.reached:
        return 1000 - robot.steps*0.5 - robot.collisions*3
    return (1-dist/maxd)*500 - robot.collisions*3 - robot.steps*0.3

def crossover(p1,p2):
    pt=random.randint(1,len(p1)-1)
    return p1[:pt]+p2[pt:], p2[:pt]+p1[pt:]

def mutate(chrom,rate=0.2):
    c=chrom[:]
    for i in range(len(c)):
        if random.random()<rate:
            lo,hi=GENE_BOUNDS[i]; c[i]=random.uniform(lo,hi)
    return c

def run_ga(grid,start,goal,callback=None):
    pop=[random_chromosome() for _ in range(POP_SIZE)]
    best_chrom,best_fit=DEFAULT_PARAMS[:],-9999
    for gen in range(N_GEN):
        scores=[(evaluate(c,grid,start,goal),c) for c in pop]
        scores.sort(key=lambda x:x[0],reverse=True)
        if scores[0][0]>best_fit: best_fit,best_chrom=scores[0]
        if callback: callback(gen+1,best_fit,best_chrom)
        elite=[s[1] for s in scores[:4]]
        new_pop=elite[:]
        while len(new_pop)<POP_SIZE:
            p=random.sample(scores[:10],2)
            c1,c2=crossover(p[0][1],p[1][1])
            new_pop.append(mutate(c1))
            if len(new_pop)<POP_SIZE: new_pop.append(mutate(c2))
        pop=new_pop
    return best_chrom,best_fit

# ══════════════════════════════════════════════
# EVALUATION
# ══════════════════════════════════════════════
def batch_evaluate(grid,start,goal,params,n_runs=5,max_steps=500):
    results=[]
    for _ in range(n_runs):
        r=Robot(start,goal,grid,fuzzy_params=params)
        r.max_steps=max_steps
        for _ in range(max_steps):
            if r.reached or r.stuck_count>30: break
            r.step()
        results.append({"success":r.reached,"steps":r.steps,
                        "collisions":r.collisions,"path_len":len(r.path)})
    succ=[r for r in results if r["success"]]
    return {
        "success_rate": len(succ)/n_runs*100,
        "avg_steps":    np.mean([r["steps"]      for r in results]),
        "avg_collisions":np.mean([r["collisions"] for r in results]),
        "avg_path_len": np.mean([r["path_len"]   for r in results]),
        "raw":          results,
    }

