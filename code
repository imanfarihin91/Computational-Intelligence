# ══════════════════════════════════════════════
# FUZZY MEMBERSHIP FUNCTIONS
# ══════════════════════════════════════════════
def trimf(x, a, b, c):
    if x <= a or x >= c: return 0.0
    if a < x <= b: return (x-a)/(b-a) if b!=a else 1.0
    return (c-x)/(c-b) if c!=b else 1.0

def trapmf(x, a, b, c, d):
    if x <= a or x >= d: return 0.0
    if b <= x <= c: return 1.0
    if a < x < b: return (x-a)/(b-a)
    return (d-x)/(d-c)

# ══════════════════════════════════════════════
# FUZZY NAVIGATOR
# Chromosome (8 genes):
#  p[0] obstacle near threshold  (1–3)
#  p[1] obstacle medium peak     (1.5–4.5)
#  p[2] obstacle far threshold   (2.5–6)
#  p[3] angle tolerance (deg)    (10–60)
#  p[4] forward bias             (0.1–0.9)
#  p[5] turn aggressiveness      (0.5–2.0)
#  p[6] loop penalty scale       (0.1–1.0)
#  p[7] side bias (0=left,1=right)(0–1)
# ══════════════════════════════════════════════
DEFAULT_PARAMS = [2.0, 3.0, 4.0, 35.0, 0.6, 1.0, 0.5, 0.5]

class FuzzyNavigator:
    def __init__(self, params=None):
        self.p = params[:] if params else DEFAULT_PARAMS[:]

    def _obs_mf(self, d):
        near = max(0.5, min(3.0, self.p[0]))
        med  = max(1.5, min(4.5, self.p[1]))
        far  = max(2.5, min(6.0, self.p[2]))
        blocked = trapmf(d, 0, 0, near-0.3, near+0.3)
        close   = trimf(d, near-0.3, med, far+0.5)
        clear   = trapmf(d, far-0.5, far+0.5, 10, 10)
        return blocked, close, clear

    def infer(self, dist_goal, angle_goal, dist_front, dist_left, dist_right,
              visit_front=0, visit_left=0, visit_right=0):
        blk_f, cl_f, clr_f = self._obs_mf(dist_front)
        blk_l, cl_l, clr_l = self._obs_mf(dist_left)
        blk_r, cl_r, clr_r = self._obs_mf(dist_right)

        ang_tol   = max(10.0, min(60.0, self.p[3]))
        fwd_bias  = max(0.1, min(0.9,  self.p[4]))
        turn_agg  = max(0.5, min(2.0,  self.p[5]))
        loop_pen  = max(0.1, min(1.0,  self.p[6]))
        side_bias = self.p[7]

        abs_ang  = abs(angle_goal)
        facing_goal = abs_ang < ang_tol     # within tolerance → go forward
        turn_left   = angle_goal < -ang_tol  # goal is to our left
        turn_right  = angle_goal >  ang_tol  # goal is to our right

        # Strengths: [Forward, TurnLeft, TurnRight, Back]
        s = [0.0, 0.0, 0.0, 0.0]

        # ── Rule set ──────────────────────────
        # R1: Path clear ahead and facing goal → strongly forward
        if clr_f > 0.3 and facing_goal:
            s[0] = max(s[0], clr_f * fwd_bias + 0.3)

        # R2: Path clear ahead but need to turn → forward still ok, weak
        if clr_f > 0.5:
            s[0] = max(s[0], clr_f * 0.3)

        # R3: Goal to left and left is clear → turn left
        if turn_left:
            strength = turn_agg * (abs_ang / 180.0)
            if clr_l > 0.3:
                s[1] = max(s[1], strength * clr_l)
            else:
                s[2] = max(s[2], strength * clr_r)  # blocked left, try right

        # R4: Goal to right and right is clear → turn right
        if turn_right:
            strength = turn_agg * (abs_ang / 180.0)
            if clr_r > 0.3:
                s[2] = max(s[2], strength * clr_r)
            else:
                s[1] = max(s[1], strength * clr_l)

        # R5: Obstacle in front → avoid
        if blk_f > 0.4:
            s[0] = max(0.0, s[0] - blk_f)
            if dist_left + (side_bias - 0.5) * 2 >= dist_right:
                s[1] = max(s[1], blk_f * 0.8)
            else:
                s[2] = max(s[2], blk_f * 0.8)

        # R6: Close obstacle in front but sides clear → choose open side
        if cl_f > 0.3:
            if clr_l > clr_r:
                s[1] = max(s[1], cl_f * 0.6)
            else:
                s[2] = max(s[2], cl_f * 0.6)

        # R7: Blocked on all sides → turn back
        if blk_f > 0.5 and blk_l > 0.5 and blk_r > 0.5:
            s[3] = max(s[3], 0.9)

        # R8: Default — always keep some forward motion if nothing else
        if max(s) < 0.05:
            if clr_f > 0.5:
                s[0] = 0.4
            elif clr_l > clr_r:
                s[1] = 0.4
            else:
                s[2] = 0.4

        # ── Loop prevention penalty ────────────
        vmax = max(visit_front, visit_left, visit_right, 1)
        s[0] = max(0.0, s[0] - (visit_front / (vmax+1)) * loop_pen)
        s[1] = max(0.0, s[1] - (visit_left  / (vmax+1)) * loop_pen)
        s[2] = max(0.0, s[2] - (visit_right / (vmax+1)) * loop_pen)

        return int(np.argmax(s)), s

