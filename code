                          (C["trail"],"Path"),(C["wall"],"Obstacle")]:
            r=tk.Frame(panel,bg=C["panel"]); r.pack(anchor="w")
            tk.Label(r,text="██",font=("Courier New",8),bg=C["panel"],fg=color).pack(side="left")
            tk.Label(r,text=f" {lbl}",font=("Courier New",8),bg=C["panel"],fg=C["sub"]).pack(side="left")

    def _build_eval_tab(self,parent):
        top=tk.Frame(parent,bg=C["bg"]); top.pack(fill="x",padx=16,pady=12)
        tk.Label(top,text="Automated Performance Evaluation  (5 runs per config)",
                 font=("Courier New",10,"bold"),bg=C["bg"],fg=C["accent"]).pack(side="left")
        self.btn_eval=tk.Button(top,text="▶  RUN EVALUATION",
                                font=("Courier New",10,"bold"),
                                bg=C["accent2"],fg=C["bg"],
                                relief="flat",cursor="hand2",padx=10,pady=4,
                                command=self.run_evaluation)
        self.btn_eval.pack(side="right")

        self.eval_status=tk.StringVar(value="Press 'RUN EVALUATION' to start.")
        tk.Label(parent,textvariable=self.eval_status,font=("Courier New",9),
                 bg=C["bg"],fg=C["warn"]).pack()
        self.eval_bar=tk.Canvas(parent,width=680,height=10,bg=C["panel"],highlightthickness=0)
        self.eval_bar.pack(pady=(2,8))

        cols=("config","map","success","steps","collisions","path_len")
        headers=("Controller","Map","Success %","Avg Steps","Avg Collisions","Avg Path Len")
        tframe=tk.Frame(parent,bg=C["bg"]); tframe.pack(fill="both",padx=16)

        style=ttk.Style()
        style.configure("Eval.Treeview",background=C["panel"],foreground=C["text"],
                        fieldbackground=C["panel"],rowheight=26,font=("Courier New",9))
        style.configure("Eval.Treeview.Heading",background=C["bg"],foreground=C["accent"],
                        font=("Courier New",9,"bold"),relief="flat")
        style.map("Eval.Treeview",background=[("selected",C["accent2"])])

        self.tree=ttk.Treeview(tframe,columns=cols,show="headings",height=8,style="Eval.Treeview")
        for col,hdr in zip(cols,headers):
            self.tree.heading(col,text=hdr); self.tree.column(col,width=108,anchor="center")
        self.tree.pack(fill="x")

        self.eval_summary=tk.Text(parent,height=7,width=80,bg=C["panel"],fg=C["text"],
                                  font=("Courier New",9),relief="flat",state="disabled",
                                  padx=10,pady=8)
        self.eval_summary.pack(padx=16,pady=(10,0))

    # ── HELPERS ───────────────────────────────
    def _on_mode_change(self):
        self.mode=self.mode_var.get(); self.load_map(self.map_var.get())

    def _make_robot(self):
        grid=self.maps[self.map_idx]; start=STARTS[self.map_idx]; goal=GOALS[self.map_idx]
        p=self.ga_params if (self.mode=="ga" and self.ga_params) else None
        self.robot=Robot(start,goal,grid,fuzzy_params=p)

    def load_map(self,idx):
        self.running=False; self.map_idx=idx
        self._make_robot(); self.draw_map(); self._update_stats()
        self.stat_vars["status"].set("Ready"); self.btn_start.configure(text="▶  START")

    def draw_map(self):
        self.canvas.delete("all")
        grid=self.maps[self.map_idx]; robot=self.robot
        for r,row in enumerate(grid):
            for c,cell in enumerate(row):
                x0,y0=c*CELL,r*CELL
                self.canvas.create_rectangle(x0,y0,x0+CELL,y0+CELL,
                    fill=C["wall"] if cell==1 else C["free"],outline="#0d1117",width=1)
        for (pr,pc) in robot.path[:-1]:
            p=5
            self.canvas.create_rectangle(pc*CELL+p,pr*CELL+p,
                pc*CELL+CELL-p,pr*CELL+CELL-p,fill=C["trail"],outline="")
        sr,sc=STARTS[self.map_idx]; self._marker(sr,sc,C["start"],"S")
        gr,gc=GOALS[self.map_idx];  self._marker(gr,gc,C["goal"],"G")
        pad=7; rr,rc=robot.row,robot.col
        x0,y0=rc*CELL+pad,rr*CELL+pad; x1,y1=x0+CELL-pad*2,y0+CELL-pad*2
        color=C["accent2"] if (self.mode=="ga" and self.ga_params) else C["robot"]
        self.canvas.create_oval(x0,y0,x1,y1,fill=color,outline="#fff",width=2)
        cx,cy=(x0+x1)//2,(y0+y1)//2
        dr,dc=DIRECTIONS[robot.facing]
        self.canvas.create_line(cx,cy,cx+dc*(CELL//2-pad-3),cy+dr*(CELL//2-pad-3),
                                fill="#0d1117",width=3,arrow="last")

    def _marker(self,r,c,color,text):
        x0,y0=c*CELL+2,r*CELL+2; x1,y1=x0+CELL-4,y0+CELL-4
        self.canvas.create_rectangle(x0,y0,x1,y1,fill=color,outline="")
        self.canvas.create_text((x0+x1)//2,(y0+y1)//2,text=text,
                                fill="#0d1117",font=("Courier New",11,"bold"))

    def start_ga_training(self):
        if self.ga_running: return
        self.ga_running=True
        self.btn_train.configure(state="disabled",text="⚙  TRAINING...")
        self.ga_status_var.set("GA running… (~15s)")
        grid=self.maps[self.map_idx]; start=STARTS[self.map_idx]; goal=GOALS[self.map_idx]
        def on_gen(gen,fit,chrom): self.root.after(0,self._ga_progress_update,gen,fit)
        def worker():
            best,fit=run_ga(grid,start,goal,callback=on_gen)
            self.root.after(0,self._ga_done,best,fit)
        threading.Thread(target=worker,daemon=True).start()

    def _ga_progress_update(self,gen,fit):
        pct=gen/N_GEN; w=int(155*pct)
        self.ga_bar.delete("all")
        self.ga_bar.create_rectangle(0,0,155,8,fill=C["bg"])
        self.ga_bar.create_rectangle(0,0,w,8,fill=C["accent2"])
        self.ga_status_var.set(f"Gen {gen}/{N_GEN}  Best: {fit:.1f}")

    def _ga_done(self,best,fit):
        self.ga_params=best; self.ga_running=False
        self.btn_train.configure(state="normal",text="⚙  RE-TRAIN GA")
        self.ga_status_var.set(f"✅ Done! Fitness: {fit:.1f}")
        self.ga_bar.delete("all")
        self.ga_bar.create_rectangle(0,0,155,8,fill=C["accent2"])
        self.mode_var.set("ga"); self.mode="ga"; self.load_map(self.map_var.get())

    def start_sim(self):
        if self.robot.reached: self.load_map(self.map_var.get()); return
        self.running=not self.running
        self.btn_start.configure(text="⏸  PAUSE" if self.running else "▶  RESUME")
        if self.running: self._run_loop()

    def _run_loop(self):
        if not self.running: return
        r=self.robot
        if r.reached or r.steps>=r.max_steps or r.stuck_count>35:
            self.running=False; self.btn_start.configure(text="▶  START")
            self._finish(); return
        r.step(); self.draw_map(); self._update_stats()
        self.root.after(self.speed,self._run_loop)

    def manual_step(self):
        r=self.robot
        if r.reached or r.steps>=r.max_steps: return
        r.step(); self.draw_map(); self._update_stats()
        if r.reached: self._finish()

    def _update_stats(self):
        r=self.robot
        self.stat_vars["mode"].set("Fuzzy+GA★" if (self.mode=="ga" and self.ga_params) else "Fuzzy Only")
        self.stat_vars["steps"].set(str(r.steps))
        self.stat_vars["dist"].set(f"{r.dist_to_goal():.1f}")
        self.stat_vars["collisions"].set(str(r.collisions))
        if r.reached: self.stat_vars["status"].set("✅ REACHED!")
        elif r.steps>=r.max_steps: self.stat_vars["status"].set("❌ Max steps")
        elif r.stuck_count>35: self.stat_vars["status"].set("⚠ Stuck!")
        else: self.stat_vars["status"].set("🔄 Running")
        self.sensor_vars["Front"].set(f"{r.sense_distance(r.facing)} cells")
        self.sensor_vars["Left"].set(f"{r.sense_distance((r.facing-1)%4)} cells")
        self.sensor_vars["Right"].set(f"{r.sense_distance((r.facing+1)%4)} cells")
        self.sensor_vars["Angle"].set(f"{r.angle_to_goal():.1f}°")

    def _finish(self):
        r=self.robot
        mode_lbl="Fuzzy+GA (Hybrid)" if (self.mode=="ga" and self.ga_params) else "Fuzzy Only"
        if r.reached:
            messagebox.showinfo("Navigation Complete",
                f"🎉 Goal Reached!\n\nController : {mode_lbl}\n"
                f"Steps      : {r.steps}\nCollisions : {r.collisions}\n"
                f"Path length: {len(r.path)} cells")
        elif r.stuck_count>35:
            messagebox.showwarning("Stuck","Robot is stuck.\nTry training GA or reset.")
        else:
            messagebox.showwarning("Failed","Max steps reached.")

    def run_evaluation(self):
        if self.ga_running:
            messagebox.showwarning("GA Running","Wait for GA training to finish first."); return
        self.btn_eval.configure(state="disabled",text="⏳  RUNNING...")
        self.eval_status.set("Running 5×4 = 20 simulations silently…")
        for item in self.tree.get_children(): self.tree.delete(item)

        def worker():
            configs=[("Fuzzy Only",None),("Fuzzy+GA ★",self.ga_params)]
            maps=[(MAP1,STARTS[0],GOALS[0],"Map 1 Simple"),
                  (MAP2,STARTS[1],GOALS[1],"Map 2 Maze")]
            all_results=[]; total=len(configs)*len(maps); done=0
            for cname,params in configs:
                for grid,start,goal,mname in maps:
                    p=params if params else DEFAULT_PARAMS
                    res=batch_evaluate(grid,start,goal,p,n_runs=5,max_steps=500)
                    all_results.append((cname,mname,res)); done+=1
                    self.root.after(0,self._eval_progress,done,total)
            self.root.after(0,self._eval_done,all_results)
        threading.Thread(target=worker,daemon=True).start()

    def _eval_progress(self,done,total):
        w=int(680*done/total)
        self.eval_bar.delete("all")
        self.eval_bar.create_rectangle(0,0,680,10,fill=C["panel"])
        self.eval_bar.create_rectangle(0,0,w,10,fill=C["accent2"])
        self.eval_status.set(f"Running… {done}/{total} configs done")

    def _eval_done(self,all_results):
        self.btn_eval.configure(state="normal",text="▶  RUN EVALUATION")
        self.eval_status.set(f"✅ Evaluation complete — {len(all_results)} configs tested")
        tag_colors={"Fuzzy Only":C["robot"],"Fuzzy+GA ★":C["accent2"]}
        for cname,mname,res in all_results:
            tag=cname.replace(" ","_").replace("★","star")
            self.tree.insert("","end",
                values=(cname,mname,f"{res['success_rate']:.0f}%",
                        f"{res['avg_steps']:.1f}",f"{res['avg_collisions']:.1f}",
                        f"{res['avg_path_len']:.1f}"),tags=(tag,))
            self.tree.tag_configure(tag,foreground=tag_colors.get(cname,C["text"]))

        lines=["="*62,
               f"  {'CONTROLLER':<20}{'MAP':<16}{'SUCCESS':>8}{'STEPS':>9}{'COLLISIONS':>12}",
               "="*62]
        for cname,mname,res in all_results:
            lines.append(f"  {cname:<20}{mname:<16}"
                         f"{res['success_rate']:>7.0f}%"
                         f"{res['avg_steps']:>9.1f}"
                         f"{res['avg_collisions']:>12.1f}")
        lines.append("="*62)
        fuzzy_rows=[r for c,m,r in all_results if "GA" not in c]
        ga_rows   =[r for c,m,r in all_results if "GA" in c]
        if fuzzy_rows and ga_rows:
            f_sr=np.mean([r["success_rate"] for r in fuzzy_rows])
            g_sr=np.mean([r["success_rate"] for r in ga_rows])
            f_st=np.mean([r["avg_steps"]    for r in fuzzy_rows])
            g_st=np.mean([r["avg_steps"]    for r in ga_rows])
            winner="Fuzzy+GA (Hybrid)" if g_sr>=f_sr else "Fuzzy Only"
            lines+=["",f"  Fuzzy Only  avg success: {f_sr:.0f}%  avg steps: {f_st:.1f}",
                    f"  Fuzzy+GA ★  avg success: {g_sr:.0f}%  avg steps: {g_st:.1f}",
                    f"","  🏆 Better overall: {winner}"]
        self.eval_summary.configure(state="normal")
        self.eval_summary.delete("1.0","end")
        self.eval_summary.insert("end","\n".join(lines))
        self.eval_summary.configure(state="disabled")

